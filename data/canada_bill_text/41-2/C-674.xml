ï»¿<?xml version="1.0" encoding="utf-8"?><Bill RHead_reign="62-63-64 Eliz. II" RHead_ParlYear="2013-2014-2015" DocumentTitle="BILL C-674" Bill_No="C-674" Document_No="412303" xml:lang="EN" Bill_Type="Non-amending" Stage_Name="First-Reading-House" Reprint="No" xml:space="preserve" ChapterNo_E="C. " ChapterNo_F="ch. " Bill-Origin="commons"><Bill_Part Part_Type="Cover" CountLines="No"><Block Align="Yes"><Para Style="CovBillNo">C-674</Para></Block><Block><Para TopMargin="24" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">Second Session, Forty-first Parliament,</Para></Block><Block><Para Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">62-63-64 Elizabeth II, 2013-2014-2015</Para></Block><Block><Para TopMargin="48" LeftMargin="0" FirstLineIndent="0" Bold="Yes" TextAlign="Center">HOUSE OF COMMONS OF CANADA</Para></Block><Block><Para TopMargin="42" Size="18" Leading="20" LeftMargin="0" FirstLineIndent="0" Bold="Yes" TextAlign="Center">BILL C-674</Para></Block><Block Align="Yes"><Para Style="CovLongTitle">An Act to establish Addiction Recovery Week</Para></Block><Block Align="Yes"><Para Style="COV_StageLine"></Para></Block><Block><Para Size="9" AllCaps="Yes" Hyphenate="OFF">first reading, May 7, 2015</Para></Block><Block Align="Yes"><Para Style="COV_StageLine"></Para></Block><Block Align="Yes"><Para Style="Cover_Sponsors"><SC SC_PerCent="85">Mr. Wilks</SC></Para></Block><Block Align="Yes"><Para Style="Cover_DocNo">412303</Para></Block></Bill_Part><Bill_Part CountLines="No" Part_Type="InsideCover"><Block Align="Yes"><Para Style="BPT_InsideCoverE">Available on the Parliament of Canada Web Site at the following address:<br /><B>http://www.parl.gc.ca</B></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><Para TopMargin="108" BottomMargin="4" Size="10" LeftMargin="0" FirstLineIndent="0" Hyphenate="OFF" TextAlign="Center">SUMMARY</Para></Block><Block LineCnt="N" Align="No"><Para TopMargin="5" Size="8" Leading="9" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">This enactment designates the week commencing on the fourth Saturday of September in each and every year as âAddiction Recovery Weekâ.</Para></Block></Bill_Part><Bill_Part Part_Type="MainText" CountLines="Yes" RunningHead_E="Addiction Recovery Week"><Block Align="Yes"><Para Style="MainText_DocNo">412303</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="Session_Reign">2nd Session, 41st Parliament,</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="Session_Reign">62-63-64 Elizabeth II, 2013-2014-2015</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="MainBillOrigin">house of commons of canada</Para></Block><Block LineCnt="N" Align="Yes"><Para Bold="Yes" Style="MAIN@BillNo_Title">BILL C-674</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="MAIN@ti;04">An Act to establish Addiction Recovery Week</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Preamble<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas drug and alcohol addiction is a health issue that impacts millions of Canadians;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas recovery from addiction free of stigma and discrimination, while being an ongoing journey, is real, available, attainable and sustainable;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas individuals, families, workplaces and communities should be celebrated for their perseverance and commitment to that recovery and to recovery-focused services;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">And whereas further support and collaboration are needed to ensure that recovery from drug and alcohol addiction, which is often part of a multidimensional personal journey towards well-being, is made available to all who are affected;</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="0" Hyphenate="ON" TextAlign="Justify">Now, therefore, Her Majesty, by and with the advice and consent of the Senate and House of Commons of Canada, enacts as follows:</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:SHORT TITLE--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">SHORT TITLE</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Short title<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>1.</B> This Act may be cited as the <I>Addiction Recovery Week Act</I>.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:ADDICTION RECOVERY WEEK--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">ADDICTION RECOVERY WEEK</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Addiction Recovery Week<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>2.</B> Throughout Canada, in each and every year, the week commencing on the fourth Saturday of September is to be known as âAddiction Recovery Weekâ.</Para></Block><Block Align="Yes"><Para Style="BPT_ImprintE"><br /><br />Published under authority of the Speaker of the House of Commons</Para></Block><Block Align="Yes" LineCnt="N"><Para NoLineBreak="Yes" NoHtml="Yes" Leading="0" Size="0" TopMargin="0" BottomMargin="0">Â</Para></Block></Bill_Part></Bill>