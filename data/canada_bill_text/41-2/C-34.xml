ГҜВ»Вҝ<?xml version="1.0" encoding="utf-8"?><Bill RHead_reign="62-63 Eliz. II" RHead_ParlYear="2013-2014" DocumentTitle="BILL C-34" Bill_No="C-34" Document_No="90728" xml:lang="EN" Bill_Type="Non-amending" Stage_Name="Assented-to" Reprint="No" xml:space="preserve" ChapterNo_E="C. 11" ChapterNo_F="ch. 11" Bill-Origin="commons"><Bill_Part Part_Type="Cover" CountLines="No"><Block><Para TopMargin="24" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">Second Session, Forty-first Parliament,</Para></Block><Block><Para Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">62-63 Elizabeth II, 2013-2014</Para></Block><Block Align="Yes"><Para Style="COV@StatutesTitle">STATUTES OF CANADA 2014<br />CHAPTER 11</Para></Block><Block Align="Yes"><Para Style="CovLongTitle">An Act to give effect to the TlaГўВҖВҷamin Final Agreement and to make consequential amendments to other Acts</Para></Block><Block Align="Yes"><Para Style="COV_StageLine"></Para></Block><Block><Para BottomMargin="14" Size="11" LeftMargin="0" FirstLineIndent="0" Bold="Yes" TextAlign="Center">ASSENTED TO</Para></Block><Block><Para Size="8" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">19th JUNE, 2014</Para></Block><Block><Para TopMargin="4" Size="8" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">BILL C-34</Para></Block><Block Align="Yes"><Para Style="COV_StageLine"></Para></Block></Bill_Part><Bill_Part CountLines="No" Part_Type="InsideCover"><Block Align="Yes"><Para Style="BPT_InsideCoverE">Available on the Parliament of Canada Web Site at the following address:<br /><B>http://www.parl.gc.ca</B></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><Para TopMargin="108" BottomMargin="4" Size="10" LeftMargin="0" FirstLineIndent="0" Hyphenate="OFF" TextAlign="Center">RECOMMENDATION</Para></Block><Block LineCnt="N" Align="No"><Para TopMargin="5" Size="8" Leading="9" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">His Excellency the Governor General recommends to the House of Commons the appropriation of public revenue under the circumstances, in the manner and for the purposes set out in a measure entitled ГўВҖВң<I>An Act to give effect to the TlaГўВҖВҷamin Final Agreement and to make consequential amendments to other Acts</I>ГўВҖВқ.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><Para TopMargin="60" BottomMargin="4" Size="10" LeftMargin="0" FirstLineIndent="0" Hyphenate="OFF" TextAlign="Center">SUMMARY</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="8" Leading="9" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">This enactment gives effect to the TlaГўВҖВҷamin Final Agreement. It also makes consequential amendments to other Acts.</Para></Block></Bill_Part><Bill_Part Part_Type="TableProvisions" CountLines="No"><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:TABLE OF PROVISIONS--><Para TopMargin="30" Size="10" Leading="12" AllCaps="Yes" Hyphenate="OFF" TextAlign="Center">TABLE OF PROVISIONS</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:AN ACT TO GIVE EFFECT TO THE TLAГўВҖВҷAMIN FINAL AGREEMENT AND TO MAKE CONSEQUENTIAL AMENDMENTS TO OTHER ACTS--><Para TopMargin="24" BottomMargin="4" Size="10" Leading="12" AllCaps="Yes" Hyphenate="OFF" TextAlign="Center">AN ACT TO GIVE EFFECT TO THE TLAГўВҖВҷAMIN FINAL AGREEMENT AND TO MAKE CONSEQUENTIAL AMENDMENTS TO OTHER ACTS</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">Preamble</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:SHORT TITLE--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">SHORT TITLE</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">1. <Tab /><I>TlaГўВҖВҷamin Final Agreement Act</I></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:INTERPRETATION--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">INTERPRETATION</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">2. <Tab />Definitions</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">3. <Tab />Status of Agreement</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:AGREEMENT--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">AGREEMENT</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">4. <Tab />Agreement given effect</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">5. <Tab />Agreement prevails</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:APPROPRIATION--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">APPROPRIATION</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">6. <Tab />Payments out of C.R.F.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:LANDS--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">LANDS</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">7. <Tab />Fee simple estate</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:TAXATION--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">TAXATION</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">8. <Tab />Tax Treatment Agreement given effect</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">9. <Tab />Clarification</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:APPLICATION OF OTHER ACTS--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">APPLICATION OF OTHER ACTS</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">10. <Tab /><I>Indian Act</I></Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">11. <Tab /><I>First Nations Land Management Act</I></Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">12. <Tab />By-laws, land code and laws</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">13. <Tab />Indemnification</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">14. <Tab /><I>Statutory Instruments Act</I></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:APPLICATION OF LAWS OF BRITISH COLUMBIA--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">APPLICATION OF LAWS OF BRITISH COLUMBIA</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">15. <Tab />Incorporation by reference</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:GENERAL--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">GENERAL</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">16. <Tab />Judicial notice of Agreements</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">17. <Tab />Judicial notice of TlaГўВҖВҷamin Laws</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">18. <Tab />Notice of issues arising</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">19. <Tab />Chapters 22 and 23 of Agreement</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">20. <Tab />Orders and regulations</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:CONSEQUENTIAL AMENDMENTS--><Para TopMargin="16" Size="9" Leading="10" Bold="Yes" Hyphenate="OFF" TextAlign="Center">CONSEQUENTIAL AMENDMENTS</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0"><B>21.</B> <Tab /><B><I>Access to Information Act</I></B></Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0"><B>22.</B> <Tab /><B><I>Fisheries Act</I></B></Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0"><B>23.</B> <Tab /><B><I>Payments in Lieu of Taxes Act</I></B></Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0"><B>24.</B> <Tab /><B><I>Privacy Act</I></B></Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0"><B>25.</B> <Tab /><B><I>First Nations Land Management Act</I></B></Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0"><B>26.</B> <Tab /><B><I>Specific Claims Tribunal Act</I></B></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:COMING INTO FORCE--><Para TopMargin="16" Size="9" Leading="10" Bold="Yes" Hyphenate="OFF" TextAlign="Center">COMING INTO FORCE</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0"><B>27.</B> <Tab /><B>Order in council</B></Para></Block></Bill_Part><Bill_Part Part_Type="MainText" CountLines="No" RunningHead_E="TlaГўВҖВҷamin Final Agreement"><Block Align="Yes"><Para Style="MAIN@RoyalAssentTitle">62-63 ELIZABETH II</Para></Block><Block Align="Yes"><Para Style="MAIN@RoyalAssentTitle">ГўВҖВ”ГўВҖВ”ГўВҖВ”ГўВҖВ”ГўВҖВ”ГўВҖВ”</Para></Block><Block Align="Yes"><Para Style="MAIN@RoyalAssentTitle">CHAPTER 11</Para></Block><Block Align="Yes"><Para Style="LongTitleAssent">An Act to give effect to the TlaГўВҖВҷamin Final Agreement and to make consequential amendments to other Acts</Para></Block><Block Align="Yes"><Para Style="MAIN@RoyalAssentDate">[<I>Assented to 19th June, 2014</I>]</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Preamble<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas the <I>Constitution Act, 1982</I> recognizes and affirms the existing Aboriginal and treaty rights of the Aboriginal peoples of Canada;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas the reconciliation between the prior presence of Aboriginal peoples and the assertion of sovereignty by the Crown is of significant social and economic importance to Canadians;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas Canadian courts have stated that this reconciliation is best achieved through negotiation;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas the TlaГўВҖВҷamin Nation is <keep>an Aborig-</keep>inal people of Canada;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas the TlaГўВҖВҷamin Nation, the Government of Canada and the Government of British Columbia have negotiated the Agreement to achieve this reconciliation and to establish a new relationship among them;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">And whereas the Agreement requires that legislation be enacted by the Parliament of Canada in order for the Agreement to be ratified;</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="0" Hyphenate="ON" TextAlign="Justify">Now, therefore, Her Majesty, by and with the advice and consent of the Senate and House of Commons of Canada, enacts as follows:</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:SHORT TITLE--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">SHORT TITLE</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Short title<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>1.</B> This Act may be cited as the <I>TlaГўВҖВҷamin Final Agreement Act</I>.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:INTERPRETATION--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">INTERPRETATION</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Definitions<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>2.</B> (1) The following definitions apply in this Act.</Para></Block><Block LineCnt="Y" Align="No"><MarginalNote>ГўВҖВңAgreementГўВҖВқ<br />ГӮВ« <I>accord</I> ГӮВ»<br /></MarginalNote><Para TopMargin="5" LeftMargin="0">ГўВҖВңAgreementГўВҖВқ means the TlaГўВҖВҷamin Final Agreement, between the TlaГўВҖВҷamin Nation, Her Majesty in right of Canada and Her Majesty in right of British Columbia, including any amendments made to it.</Para></Block><Block LineCnt="Y" Align="No"><MarginalNote>ГўВҖВңTax Treatment AgreementГўВҖВқ<br />ГӮВ« <I>accord sur le traitement fiscal</I> ГӮВ»<br /></MarginalNote><Para TopMargin="5" LeftMargin="0">ГўВҖВңTax Treatment AgreementГўВҖВқ means the tax treatment agreement referred to in paragraph 22 of Chapter 21 of the Agreement, including any amendments made to it.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Definitions in Agreement<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(2) In this Act, ГўВҖВңFormer Sliammon Indian ReservesГўВҖВқ, ГўВҖВңOther TlaГўВҖВҷamin LandsГўВҖВқ, ГўВҖВңSliammon Indian BandГўВҖВқ, ГўВҖВңTlaГўВҖВҷamin CitizenГўВҖВқ, ГўВҖВңTlaГўВҖВҷamin CorporationГўВҖВқ, ГўВҖВңTlaГўВҖВҷamin GovernmentГўВҖВқ, ГўВҖВңTlaГўВҖВҷamin LandsГўВҖВқ, ГўВҖВңTlaГўВҖВҷamin LawГўВҖВқ, ГўВҖВңTlaГўВҖВҷamin NationГўВҖВқ and ГўВҖВңTlaГўВҖВҷamin Public InstitutionГўВҖВқ have the same meanings as in Chapter 1 of the Agreement.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Status of Agreement<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>3.</B> The Agreement is a treaty and a land claims agreement within the meaning of sections 25 and 35 of the <I>Constitution Act, 1982</I>.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:AGREEMENT--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">AGREEMENT</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Agreement given effect<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>4.</B> (1) The Agreement is approved, given effect and declared valid and has the force of law.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Rights and obligations<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(2) For greater certainty, any person or body referred to in the Agreement has the powers, rights, privileges and benefits conferred on the person or body by the Agreement and must perform the duties, and is subject to the liabilities, imposed on the person or body by the Agreement.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Third parties<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(3) For greater certainty, the Agreement is binding on, and may be relied on by, all persons and bodies.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Agreement prevails<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>5.</B> (1) The Agreement prevails over this Act and any other federal law to the extent of any inconsistency between them.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Act prevails<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(2) This Act prevails over any other federal law to the extent of any conflict between them.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:APPROPRIATION--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">APPROPRIATION</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Payments out of C.R.F.<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>6.</B> There must be paid out of the Consolidated Revenue Fund any sums that are required to meet the monetary obligations of Her Majesty in right of Canada under Chapters 18 and 19 of the Agreement.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:LANDS--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">LANDS</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Fee simple estate<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>7.</B> On the effective date of the Agreement, the TlaГўВҖВҷamin Nation owns the estate in fee simple, as set out in Chapter 3 of the Agreement, in the TlaГўВҖВҷamin Lands, except for the lands described in Part 1 of Appendix C-3 of the Agreement, and in the Other TlaГўВҖВҷamin Lands.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:TAXATION--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">TAXATION</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Tax Treatment Agreement given effect<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>8.</B> The Tax Treatment Agreement is approved, given effect and declared valid and has the force of law during the period that it is in effect.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Clarification<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>9.</B> The Tax Treatment Agreement does not form part of the Agreement and is not a treaty or a land claims agreement within the meaning of sections 25 and 35 of the <I>Constitution Act, 1982</I>.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:APPLICATION OF OTHER ACTS--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">APPLICATION OF OTHER ACTS</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote><I>Indian Act</I><br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>10.</B> Subject to section 12, to the provisions of Chapter 17 of the Agreement that deal with the continuing application of the <I>Indian Act</I> and to paragraphs 16 to 21 of Chapter 21 of the Agreement, the <I>Indian Act</I> does not apply to the TlaГўВҖВҷamin Nation, TlaГўВҖВҷamin Citizens, the TlaГўВҖВҷamin Government, TlaГўВҖВҷamin Public Institutions, TlaГўВҖВҷamin Lands or Other TlaГўВҖВҷamin Lands as of the effective date of the Agreement, except for the purpose of determining whether <keep>an individ-</keep>ual is an Indian.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote><I>First Nations Land Management Act</I><br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>11.</B> Subject to section 12, the <I>First Nations Land Management Act</I>, the Framework Agreement as defined in subsection 2(1) of that Act and the <I>Sliammon First Nation Land Code</I> adopted under subsection 6(1) of that Act do not apply to the TlaГўВҖВҷamin Nation, TlaГўВҖВҷamin Citizens, the TlaГўВҖВҷamin Government, TlaГўВҖВҷamin Public Institutions or TlaГўВҖВҷamin Lands as of the effective date of the Agreement.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>By-laws, land code and laws<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>12.</B> (1) If a by-law made by the Sliammon Indian Band under the <I>Indian Act</I>, the <I>Sliammon First Nation Land Code</I> or a law made under the <I>First Nations Land Management Act</I> and made in accordance with that land code is in effect immediately before the effective date of the Agreement, it continues to be in effect on the Former Sliammon Indian Reserves for a period of 90 days beginning on that date.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Repeal<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(2) However, during that period, the TlaГўВҖВҷamin Nation may repeal a by-law or law or the land code. Once repealed, the by-law, law or land code ceases to have effect.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Indemnification<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>13.</B> For as long as the <I>First Nations Land Management Act</I> is in force, Her Majesty in right of Canada or the TlaГўВҖВҷamin Nation, as the case may be, must, as of the effective date of the Agreement, indemnify the other in respect of anything done or omitted to be done in relation to the Former Sliammon Indian Reserves, in the same manner and under the same conditions as would be applicable if that Act continued to apply to the Former Sliammon Indian Reserves.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote><I>Statutory Instruments Act</I><br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>14.</B> TlaГўВҖВҷamin Laws and other instruments made under the Agreement are not statutory instruments for the purposes of the <I>Statutory Instruments Act</I>.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:APPLICATION OF LAWS OF BRITISH COLUMBIA--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">APPLICATION OF LAWS OF BRITISH COLUMBIA</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Incorporation by reference<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>15.</B> To the extent that a law of British Columbia does not apply of its own force to the TlaГўВҖВҷamin Nation, TlaГўВҖВҷamin Citizens, the TlaГўВҖВҷamin Government, TlaГўВҖВҷamin Public Institutions, TlaГўВҖВҷamin Corporations, TlaГўВҖВҷamin Lands or Other TlaГўВҖВҷamin Lands, because of the exclusive legislative authority of Parliament set out in Class 24 of section 91 of the <I>Constitution Act, 1867</I>, that law of British Columbia applies to it or to them by virtue of this section, in accordance with the Agreement and subject to this Act and any other Act of Parliament.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:GENERAL--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">GENERAL</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Judicial notice of Agreements<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>16.</B> (1) Judicial notice must be taken of the Agreement and the Tax Treatment Agreement.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Publication of Agreements<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(2) The Agreement and the Tax Treatment Agreement must be published by the QueenГўВҖВҷs Printer.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Evidence<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(3) A copy of the Agreement or the Tax Treatment Agreement published by the QueenГўВҖВҷs Printer is evidence of that agreement and of its contents, and a copy purporting to be published by the QueenГўВҖВҷs Printer is presumed to be so published unless the contrary is shown.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Judicial notice of TlaГўВҖВҷamin Laws<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>17.</B> (1) Judicial notice must be taken of TlaГўВҖВҷamin Laws.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Evidence of TlaГўВҖВҷamin Laws<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(2) A copy of a TlaГўВҖВҷamin Law purporting to be deposited in the public registry referred to in subparagraph 19.a of Chapter 15 of the Agreement is evidence of that law and of its contents, unless the contrary is shown.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Notice of issues arising<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>18.</B> (1) If an issue arises in any judicial or administrative proceeding in respect of the interpretation or validity of the Agreement, or the validity or applicability of this Act, the British Columbia <I>TlaГўВҖВҷamin Final Agreement Act</I> or any TlaГўВҖВҷamin Law, then the issue must not be decided until the party raising the issue has served notice on the Attorney General of Canada, the Attorney General of British Columbia and the TlaГўВҖВҷamin Nation.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Content and timing<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(2) The notice must</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>a</I>) describe the proceeding;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>b</I>) specify the subject matter of the issue;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>c</I>) state the day on which the issue is to be argued;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>d</I>) give the particulars that are necessary to show the point to be argued; and</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>e</I>) be served at least 14 days before the day of argument, unless the court or tribunal authorizes a shorter period.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Participation in proceedings<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(3) The Attorney General of Canada, the Attorney General of British Columbia and the TlaГўВҖВҷamin Nation may appear and participate in any proceeding in respect of which subsection (1) applies as parties with the same rights as any other party.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Saving<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2">(4) For greater certainty, subsections (2) and (3) do not require that an oral hearing be held if one is not otherwise required.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Chapters 22 and 23 of Agreement<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>19.</B> Despite subsection 4(1), Chapters 22 and 23 of the Agreement are deemed to have effect as of April 1, 2009.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Orders and regulations<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>20.</B> The Governor in Council may make any orders and regulations that are necessary for the purpose of carrying out any of the provisions of the Agreement or of the Tax Treatment Agreement.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:CONSEQUENTIAL AMENDMENTS--><Para TopMargin="10" Bold="Yes" Hyphenate="OFF" TextAlign="Center">CONSEQUENTIAL AMENDMENTS</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:Access to Information Act--><MarginalNote>R.S., c. A-1<br /></MarginalNote><Para TopMargin="5" Bold="Yes" SmallCaps="Yes" Hyphenate="OFF" TextAlign="Center">Access to Information Act</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Bold="Yes"><B>21.</B> Subsection 13(3) of the <I>Access to Information Act</I> is amended by adding the following after paragraph (<I>e</I>):</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>e.1</I>) the TlaГўВҖВҷamin Government, as defined in subsection 2(2) of the <I>TlaГўВҖВҷamin Final Agreement Act</I>;</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:Fisheries Act--><MarginalNote>R.S., c. F-14<br /></MarginalNote><Para TopMargin="10" Bold="Yes" SmallCaps="Yes" Hyphenate="OFF" TextAlign="Center">Fisheries Act</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Bold="Yes"><B>22.</B> Subsection 5(4) of the <I>Fisheries Act</I> is amended by adding the following after paragraph (<I>a</I>):</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>a.1</I>) TlaГўВҖВҷamin Laws, as defined in subsection 2(2) of the <I>TlaГўВҖВҷamin Final Agreement Act</I>, made under Chapter 9 of the Agreement, as defined in subsection 2(1) of that Act, given effect by that Act;</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:Payments in Lieu of Taxes Act--><MarginalNote>R.S., c. M-13; 2000, c. 8, s. 2<br /></MarginalNote><Para TopMargin="10" Bold="Yes" SmallCaps="Yes" Hyphenate="OFF" TextAlign="Center">Payments in Lieu of Taxes Act</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Bold="Yes"><B>23.</B> The definition ГўВҖВңtaxing authorityГўВҖВқ in subsection 2(1) of the <I>Payments in Lieu of Taxes Act</I> is amended by adding the following after paragraph (<I>h</I>):</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>h.1</I>) the TlaГўВҖВҷamin Government, as defined in subsection 2(2) of the <I>TlaГўВҖВҷamin Final Agreement Act</I>, if it levies and collects a real property tax or a frontage or area tax in respect of TlaГўВҖВҷamin Lands, as defined in that subsection;</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:Privacy Act--><MarginalNote>R.S., c. P-21<br /></MarginalNote><Para TopMargin="10" Bold="Yes" SmallCaps="Yes" Hyphenate="OFF" TextAlign="Center">Privacy Act</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Bold="Yes"><B>24.</B> Subsection 8(7) of the <I>Privacy Act</I> is amended by adding the following after paragraph (<I>e</I>):</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="2" FirstLineIndent="0">(<I>e.1</I>) the TlaГўВҖВҷamin Government, as defined in subsection 2(2) of the <I>TlaГўВҖВҷamin Final Agreement Act</I>;</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:First Nations Land Management Act--><MarginalNote>1999, c. 24<br /></MarginalNote><Para TopMargin="10" Bold="Yes" SmallCaps="Yes" Hyphenate="OFF" TextAlign="Center">First Nations Land Management Act</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>SOR/2003-178, s. 1; 2012, c. 19, ss. 638 and 645<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Bold="Yes"><B>25.</B> Item 30 of the schedule to the <I>First Nations Land Management Act</I> is repealed.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:Specific Claims Tribunal Act--><MarginalNote>2008, c. 22<br /></MarginalNote><Para TopMargin="10" Bold="Yes" SmallCaps="Yes" Hyphenate="OFF" TextAlign="Center">Specific Claims Tribunal Act</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Bold="Yes"><B>26.</B> Part 1 of the schedule to the <I>Specific Claims Tribunal Act</I> is amended by adding the following in alphabetical order:</Para></Block><Block LineCnt="Y" Align="Yes" KeepWith="Next"><Para TopMargin="2" LeftMargin="2" FirstLineIndent="-2">TlaГўВҖВҷamin Final Agreement Act</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="0" LeftMargin="4" FirstLineIndent="-2" Italic="Yes"><AltLang xml:lang="fr">Loi sur lГўВҖВҷaccord dГғВ©finitif concernant les Tlaamins</AltLang></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:COMING INTO FORCE--><Para TopMargin="10" Bold="Yes" Hyphenate="OFF" TextAlign="Center">COMING INTO FORCE</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Order in council<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Bold="Yes"><B>27.</B> The provisions of this Act, other than section 19, come into force on a day to be fixed by order of the Governor in Council.</Para></Block><Block Align="Yes"><Para Style="BPT_ImprintE"><br /><br />Published under authority of the Speaker of the House of Commons</Para></Block><Block Align="Yes" LineCnt="N"><Para NoLineBreak="Yes" NoHtml="Yes" Leading="0" Size="0" TopMargin="0" BottomMargin="0">ГӮВ„</Para></Block></Bill_Part></Bill>