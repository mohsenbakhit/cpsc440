ï»¿<?xml version="1.0" encoding="utf-8"?><Bill RHead_reign="62-63 Eliz. II" RHead_ParlYear="2013-2014" DocumentTitle="BILL C-635" Bill_No="C-635" Document_No="412170" xml:lang="EN" Bill_Type="Non-amending" Stage_Name="First-Reading-House" Reprint="No" xml:space="preserve" ChapterNo_E="C. " ChapterNo_F="ch. " Bill-Origin="commons"><Bill_Part Part_Type="Cover" CountLines="No"><Block Align="Yes"><Para Style="CovBillNo">C-635</Para></Block><Block><Para TopMargin="24" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">Second Session, Forty-first Parliament,</Para></Block><Block><Para Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">62-63 Elizabeth II, 2013-2014</Para></Block><Block><Para TopMargin="48" LeftMargin="0" FirstLineIndent="0" Bold="Yes" TextAlign="Center">HOUSE OF COMMONS OF CANADA</Para></Block><Block><Para TopMargin="42" Size="18" Leading="20" LeftMargin="0" FirstLineIndent="0" Bold="Yes" TextAlign="Center">BILL C-635</Para></Block><Block Align="Yes"><Para Style="CovLongTitle">An Act to establish Latin-American Heritage Day</Para></Block><Block Align="Yes"><Para Style="COV_StageLine"></Para></Block><Block><Para Size="9" AllCaps="Yes" Hyphenate="OFF">first reading, November 6, 2014</Para></Block><Block Align="Yes"><Para Style="COV_StageLine"></Para></Block><Block Align="Yes"><Para Style="Cover_Sponsors"><SC SC_PerCent="85">Ms. Ayala</SC></Para></Block><Block Align="Yes"><Para Style="Cover_DocNo">412170</Para></Block></Bill_Part><Bill_Part CountLines="No" Part_Type="InsideCover"><Block Align="Yes"><Para Style="BPT_InsideCoverE">Available on the Parliament of Canada Web Site at the following address:<br /><B>http://www.parl.gc.ca</B></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><Para TopMargin="108" BottomMargin="4" Size="10" LeftMargin="0" FirstLineIndent="0" Hyphenate="OFF" TextAlign="Center">SUMMARY</Para></Block><Block LineCnt="N" Align="No"><Para TopMargin="5" Size="8" Leading="9" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">This enactment designates the 5th of October in each and every year as âLatin-American Heritage Dayâ.</Para></Block></Bill_Part><Bill_Part Part_Type="MainText" CountLines="Yes" RunningHead_E="Latin-American Heritage Day"><Block Align="Yes"><Para Style="MainText_DocNo">412170</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="Session_Reign">2nd Session, 41st Parliament,</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="Session_Reign">62-63 Elizabeth II, 2013-2014</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="MainBillOrigin">house of commons of canada</Para></Block><Block LineCnt="N" Align="Yes"><Para Bold="Yes" Style="MAIN@BillNo_Title">BILL C-635</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="MAIN@ti;04">An Act to establish Latin-American Heritage Day</Para></Block><Block LineCnt="Y" Align="No"><MarginalNote>Preamble<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas the members of the Latin-American community are a visible minority that arrived in Canada relatively recently;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas this community is extremely economically, politically, religiously and ethnically heterogeneous, and its members come from over twenty countries;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas the members of that community are established throughout Canada and, since their arrival, have played a major role, including in the development of the arts, economics, politics, science and community agencies in Canada;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas a number of Canadian municipalities and provinces have instituted a day to recognize the Latin-American community;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas there is a growing demand from members of that community to be recognized and participate in political life;</Para></Block><Block LineCnt="Y" Align="No"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">And whereas Canada wants to strengthen and encourage the participation of all members of Canadian society of immigrant origin in public life;</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="0" Hyphenate="ON" TextAlign="Justify">Now, therefore, Her Majesty, by and with the advice and consent of the Senate and House of Commons of Canada, enacts as follows:</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:SHORT TITLE--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">SHORT TITLE</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Short title<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>1.</B> This Act may be cited as the <I>Latin-American Heritage Day Act</I>.</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:LATIN-AMERICAN HERITAGE DAY--><Para TopMargin="10" Hyphenate="OFF" TextAlign="Center">LATIN-AMERICAN HERITAGE DAY</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Latin-American Heritage Day<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>2.</B> Throughout Canada, in each and every year, the 5th day of October is to be known as âLatin-American Heritage Dayâ.</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Not a legal holiday <br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><B>3.</B> For greater certainty, Latin-American Heritage Day is not a legal holiday or a non-juridical day.</Para></Block><Block Align="Yes"><Para Style="BPT_ImprintE"><br /><br />Published under authority of the Speaker of the House of Commons</Para></Block><Block Align="Yes" LineCnt="N"><Para NoLineBreak="Yes" NoHtml="Yes" Leading="0" Size="0" TopMargin="0" BottomMargin="0">Â</Para></Block></Bill_Part></Bill>