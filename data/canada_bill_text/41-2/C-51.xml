lign="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">26. <Tab />Proof of documents</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">27. <Tab />Document entries as proof</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:INSPECTION POWERS--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">INSPECTION POWERS</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">28. <Tab />Powers to enter, seize and detain</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">29. <Tab />No offence</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">30. <Tab />Duty to assist Minister</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">31. <Tab />Compliance order</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:REGULATIONS--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">REGULATIONS</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">32. <Tab />Regulations</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:TRANSITIONAL PROVISION--><Para TopMargin="16" Size="9" Leading="10" Hyphenate="OFF" TextAlign="Center">TRANSITIONAL PROVISION</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0">33. <Tab />Section 16</Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><!--Heading:Consequential Amendments--><Para TopMargin="16" Size="9" Leading="10" Bold="Yes" SmallCaps="Yes" Hyphenate="OFF" TextAlign="Center">Consequential Amendments</Para></Block><Block 