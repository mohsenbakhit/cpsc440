ara></Block><Block Align="Yes"><Para Style="Cov_EndBox"></Para></Block><Block Align="Yes"><Para Style="Cover_Sponsors"><SC SC_PerCent="85">Mr. Stoffer</SC></Para></Block><Block Align="Yes"><Para Style="Cover_DocNo">411530</Para></Block></Bill_Part><Bill_Part CountLines="No" Part_Type="InsideCover"><Block Align="Yes"><Para Style="BPT_InsideCoverE">Available on the Parliament of Canada Web Site at the following address:<br /><B>http://www.parl.gc.ca</B></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><Para TopMargin="108" BottomMargin="4" Size="10" LeftMargin="0" FirstLineIndent="0" Hyphenate="OFF" TextAlign="Center">SUMMARY</Para></Block><Block LineCnt="N" Align="No"><Para TopMargin="5" Size="8" Leading="9" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">This enactment proclaims Edison Arantes do Nascimento an honorary citizen of Canada.</Para></Block></Bill_Part><Bill_Part Part_Type="MainText" CountLines="Yes" RunningHead_E="Edison Arantes do Nascimento Honorary Citizenship"><Block Align="Yes"><Para Style="MainText_DocNo">411530</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="Session_Reign">1st Session, 41st Parliament,</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="Session_Reign">60-61 Elizabeth II, 2011-2012</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="MainBillOrigin">house of commons of canada</Para></Block><Block LineCnt="N" Align="Yes"><Para Bold="Yes" Style="MAIN@BillNo_Title">BILL C-416</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="MAIN@ti;04">An Act to proclaim Edison Arantes do Nascimento an honorary citizen of Canada</Para></Block><Block LineCnt="Y" Align="No"><MarginalNote>Preamble<br /></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Whereas Edison Arantes do Nascimento, best known by the nickname âPelÃ©â, is widely regarded as the greatest soccer player of all time;</Para></Block><Block LineCnt="Y" Align="No"><Para