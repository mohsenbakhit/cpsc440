<Bill RHead_reign="49-50 Eliz. II" RHead_ParlYear="2001" DocumentTitle="BILL S-29" Bill_No="S-29" Document_No="2506" xml:lang="EN" Bill_Type="Non-amending" Stage_Name="First-Reading-Senate" Reprint="No" xml:space="preserve" ChapterNo_E="C. " ChapterNo_F="ch. " Bill-Origin="senate"><Bill_Part Part_Type="Cover" CountLines="No"><Block Align="Yes"><Para Style="CovBillNo">S-29</Para></Block><Block><Para TopMargin="24" Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">First Session, Thirty-seventh Parliament,</Para></Block><Block><Para Size="9" Leading="10" LeftMargin="0" FirstLineIndent="0" TextAlign="Center">49-50 Elizabeth II, 2001</Para></Block><Block><Para TopMargin="48" LeftMargin="0" FirstLineIndent="0" Bold="Yes" TextAlign="Center">SENATE OF CANADA</Para></Block><Block><Para TopMargin="42" Size="18" Leading="20" LeftMargin="0" FirstLineIndent="0" Bold="Yes" TextAlign="Center">BILL S-29</Para></Block><Block Align="Yes"><Para Style="CovLongTitle">An Act to amend the Broadcasting Act (review of decisions)</Para></Block><Block Align="Yes"><Para Style="COV_StageLine"></Para></Block><Block><Para Size="9" AllCaps="Yes" Hyphenate="OFF">first reading, June 11, 2001</Para></Block><Block Align="Yes"><Para Style="COV_StageLine"></Para></Block><Block Align="Yes"><Para Style="Cover_Sponsors"><SC SC_PerCent="85">The Honourable Senator Gauthier</SC></Para></Block><Block Align="Yes"><Para Style="Cover_DocNo">2506</Para></Block></Bill_Part><Bill_Part CountLines="No" Part_Type="InsideCover"><Block Align="Yes"><Para Style="BPT_InsideCoverE">Available on the Parliament of Canada Web Site at the following address:<br/><B>http://www.parl.gc.ca</B></Para></Block><Block LineCnt="N" Align="Yes" KeepWith="Next"><Para TopMargin="108" BottomMargin="4" Size="10" LeftMargin="0" FirstLineIndent="0" Hyphenate="OFF" TextAlign="Center"><SC SC_PerCent="85">Summary</SC></Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="8" Leading="9" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">This enactment amends the <I>Broadcasting Act</I> to expand the powers of internal review of the Canadian Radio-television and Telecommunications Commission for the purposes of this Act and for the sake of consistency with the <I>Telecommunications Act</I>.</Para></Block><Block LineCnt="N" Align="Yes"><Para TopMargin="5" Size="8" Leading="9" LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Henceforth, the Commission may review, rescind or vary its decisions and may re-hear any matter before rendering a decision.</Para></Block></Bill_Part><Bill_Part Part_Type="MainText" CountLines="Yes" RunningHead_E="Broadcasting Act"><Block Align="Yes"><Para Style="MainText_DocNo">2506</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="Session_Reign">1st Session, 37th Parliament,</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="Session_Reign">49-50 Elizabeth II, 2001</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="MainBillOrigin">senate of canada</Para></Block><Block LineCnt="N" Align="Yes"><Para Bold="Yes" Style="MAIN@BillNo_Title">BILL S-29</Para></Block><Block LineCnt="N" Align="Yes"><Para Style="MAIN@ti;04">An Act to amend the Broadcasting Act (review of decisions)</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>1991, c. 11<br/></MarginalNote><Para LeftMargin="0" FirstLineIndent="2" Hyphenate="ON" TextAlign="Justify">Her Majesty, by and with the advice and consent of the Senate and House of Commons of Canada, enacts as follows:</Para></Block><Block LineCnt="Y" Align="Yes"><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2" Bold="Yes"><B>1.</B> The <I>Broadcasting Act</I> is amended by adding the following after section 31:</Para></Block><Block LineCnt="Y" Align="Yes"><MarginalNote>Review of decisions<br/></MarginalNote><Para TopMargin="5" LeftMargin="0" FirstLineIndent="2"><change><B>31.1</B> The Commission may, on application or on its own motion, review and rescind or vary any decision made by it or re-hear a matter before rendering a decision.</change></Para></Block><Block Align="Yes"><Para Style="BPT_ImprintE"><br/><br/>Published under authority of the Senate of Canada</Para></Block><Block Align="Yes" LineCnt="N"><Para NoLineBreak="Yes" NoHtml="Yes" Leading="0" Size="0" TopMargin="0" BottomMargin="0">Â</Para></Block></Bill_Part></Bill>
